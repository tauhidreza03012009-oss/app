html, input, button, textarea { color: rgb(25, 27, 38); font-family: "Open Sans", Arial, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans", Ubuntu, Cantarell, "Helvetica Neue"; }

body, label, button, input, textarea { font-size: 14px; font-weight: 400; }

@media (max-width: 768px) {
  input, textarea { font-size: 16px; line-height: 20px; }
  input::-webkit-input-placeholder { font-size: 14px; line-height: 20px; }
  input::placeholder { font-size: 14px; line-height: 20px; }
  textarea::-webkit-input-placeholder { font-size: 14px; line-height: 20px; }
  textarea::placeholder { font-size: 14px; line-height: 20px; }
}

body { color: rgb(25, 27, 38); padding-right: 0px; padding-bottom: 0px; padding-left: 0px; padding-top: env(safe-area-inset-top); }

a { color: rgb(0, 171, 107); text-decoration: none; }

a:hover { color: rgb(20, 188, 125); text-decoration: underline; }

table { border-collapse: collapse; }

table th { text-align: center; border: 1px solid rgba(25, 27, 38, 0.08); padding: 8px; font-weight: 600; }

table td { text-align: center; border: 1px solid rgba(25, 27, 38, 0.08); padding: 8px; }

table tfoot td { border-top: 2px solid rgba(25, 27, 38, 0.64); }

h1 { font-size: 32px; font-weight: 700; }

h2 { color: rgba(25, 27, 38, 0.64); font-size: 24px; font-weight: 600; }

hr { border-style: solid; border-color: rgba(25, 27, 38, 0.08); border-top-width: 0px; margin: 16px 0px; }

input[type="search"]::-webkit-search-decoration { appearance: none; }

input[type="search"]::-webkit-search-cancel-button { appearance: none; }

input[type="search"]::-webkit-search-results-button { appearance: none; }

input[type="search"]::-webkit-search-results-decoration { appearance: none; }

#ot-sdk-btn-floating { display: none !important; }

.hidden { visibility: hidden; width: 1px; height: 1px; position: absolute; }

.container--wzc4c { align-items: center; gap: 16px; min-height: 76px; display: flex; }

.container--wzc4c .titles--JdOPb { flex: 1 1 auto; }

.container--wzc4c .titles--JdOPb h2 { margin: 8px 0px 0px; font-size: 14px; font-weight: 400; }

.container--wzc4c .userInfo--g3bka { border: 1px solid rgba(25, 27, 38, 0.08); border-radius: 8px; align-items: center; width: 264px; padding: 16px; display: flex; }

.container--wzc4c .userInfo--g3bka .profileImage--tdQgw { flex-shrink: 0; }

.container--wzc4c .userInfo--g3bka .rankingDisplay--ZnrNQ { flex-wrap: wrap; flex: 1 1 auto; margin-left: 12px; }

.container--wzc4c .userInfo--g3bka .rankingDisplay--ZnrNQ .name--VqrhB { font-weight: 600; }

.container--wzc4c .userInfo--g3bka .rankingDisplay--ZnrNQ .rank--G68LU { color: rgba(25, 27, 38, 0.64); font-weight: 600; }

@media (max-width: 768px) {
  .container--wzc4c { flex-wrap: wrap; }
  .container--wzc4c .userInfo--g3bka { width: 100%; }
  .container--wzc4c .userInfo--g3bka .rankingDisplay--ZnrNQ { align-items: center; display: flex; }
  .container--wzc4c .userInfo--g3bka .rankingDisplay--ZnrNQ .name--VqrhB { flex: 1 1 auto; }
}

.container--BgVhQ { flex-direction: column; align-items: center; padding-bottom: 32px; display: flex; }

@media (max-width: 768px) {
  .container--BgVhQ { padding-bottom: 16px; }
}

.container--BgVhQ .headerSection--FSnJU { text-align: center; flex-direction: column; margin-top: 40px; display: flex; }

@media (max-width: 768px) {
  .container--BgVhQ .headerSection--FSnJU { margin-top: 24px; }
}

.container--BgVhQ .headerSection--FSnJU h1 { margin-bottom: 8px; font-size: 32px; }

@media (max-width: 768px) {
  .container--BgVhQ .headerSection--FSnJU h1 { font-size: 20px; }
}

.container--BgVhQ .headerSection--FSnJU h2 { font-size: 14px; font-weight: 400; }

@media (max-width: 768px) {
  .container--BgVhQ .headerSection--FSnJU h2 { margin-top: 0px; margin-bottom: 0px; }
}

.container--BgVhQ .headerSection--FSnJU a { color: rgb(25, 27, 38); font-size: 14px; text-decoration: underline; }

.container--BgVhQ .cardsSection--Kmrdm { flex-direction: row; gap: 24px; margin-top: 40px; margin-bottom: 80px; display: flex; }

@media (max-width: 1024px) {
  .container--BgVhQ .cardsSection--Kmrdm { flex-direction: column; gap: 12px; width: 100%; margin-top: 24px; margin-bottom: 24px; }
}

.container--BgVhQ .cardsSection--Kmrdm .guidelineCard--catky { border: 1px solid rgba(25, 27, 38, 0.08); border-radius: 8px; flex-direction: column; align-items: flex-start; gap: 16px; width: 360px; height: 288px; padding: 24px; display: flex; }

@media (max-width: 1024px) {
  .container--BgVhQ .cardsSection--Kmrdm .guidelineCard--catky { width: 100%; height: auto; }
}

.container--BgVhQ .cardsSection--Kmrdm .guidelineCard--catky .iconContainer--oPIKa { background-color: rgba(25, 27, 38, 0.04); border-radius: 100px; justify-content: center; align-items: center; width: 40px; height: 40px; display: flex; }

.container--BgVhQ .cardsSection--Kmrdm .guidelineCard--catky .cardText--yJj6c { color: rgba(25, 27, 38, 0.64); }

.container--BgVhQ .cardsSection--Kmrdm .guidelineCard--catky .cardText--yJj6c b { font-size: 14px; font-weight: 600; }

.container--BgVhQ .cardsSection--Kmrdm .guidelineCard--catky .link--BT8od { color: rgba(25, 27, 38, 0.64); align-items: center; gap: 4px; text-decoration: underline; display: flex; }

.container--BgVhQ .divider--hDRbq { width: 100vw; margin-top: 0px; margin-bottom: 0px; }

.container--BgVhQ .footerSection--li_yc { flex-direction: column; align-items: center; gap: 24px; display: flex; }

.container--BgVhQ .footerSection--li_yc .checkboxText--uHdeq { font-weight: 400; }

@media (max-width: 1024px) {
  .container--BgVhQ .footerSection--li_yc { flex-direction: row; justify-content: space-between; width: 100%; padding-top: 16px; }
}

.container--X_WPL { text-align: left; margin: 0px -56px; padding: 0px 56px; position: relative; }

.container--X_WPL .itemContainer--zcp64 { background: rgb(255, 255, 255); border: 1px solid rgba(25, 27, 38, 0.08); border-radius: 12px; display: flex; position: relative; }

.container--X_WPL .itemContainer--zcp64.itemIsDeleting--h_Vc_ { opacity: 0.4; }

.container--X_WPL .itemContainer--zcp64 .previewComponent--mgta7 { border-top-left-radius: inherit; border-bottom-left-radius: inherit; background-color: rgb(247, 247, 247); border-top-right-radius: 0px; border-bottom-right-radius: 0px; align-content: center; width: 360px; position: relative; overflow: hidden; }

.container--X_WPL .itemContainer--zcp64 .previewComponent--mgta7 .uploadProgress--VHynQ { z-index: 1; position: absolute; inset: 0px; }

.container--X_WPL .itemContainer--zcp64 .previewComponent--mgta7 .uploadProgress--VHynQ.fadeIn--Xuq6Y { opacity: 0; }

.container--X_WPL .itemContainer--zcp64 .previewComponent--mgta7 .uploadProgress--VHynQ.fadeIn--Xuq6Y.fadeInActive--u5cxr { opacity: 1; transition: opacity 0.3s; }

